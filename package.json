{
  "name": "cylinder-seal-studio",
  "private": true,
  "version": "0.1.0",
  "description": "A browser-based raster-to-cylinder-relief generator for STL and SVG fabrication files.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorrivin/cylinder-seal-studio.git"
  },
  "homepage": "https://github.com/igorrivin/cylinder-seal-studio#readme",
  "bugs": "https://github.com/igorrivin/cylinder-seal-studio/issues",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --omit=dev --audit-level=high",
    "benchmark:svg": "SVG_BENCHMARK_WRITE=1 vitest run benchmarks/svg-gold/gold-standard.test.ts --testTimeout=30000",
    "check": "npm run lint && npm test && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-radio-group": "^1.4.4",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-separator": "^1.1.12",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "vectortracer": "^0.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@resvg/resvg-js": "2.6.2",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "postcss": "^8.5.21",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
